# ============================================================
# 前端 helper-admin（Vue 3 / Vite）忽略规则
# ============================================================

# ===================== 依赖（核心过滤） =====================
node_modules/

# ===================== 构建产物 =====================
dist/
dist-ssr/
*.local

# ===================== 本地环境变量（含密钥勿上传） =====================
# 注意：.env.development 仅含本地地址，可按需保留或加入忽略
.env.local
.env.*.local

# ===================== 日志 =====================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
pnpm-lock.yaml

# ===================== IDE / 编辑器 =====================
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ===================== 缓存 / 类型产物 =====================
.cache/
*.tsbuildinfo
.eslintcache
.stylelintcache

# ===================== 操作系统 =====================
.DS_Store
Thumbs.db
